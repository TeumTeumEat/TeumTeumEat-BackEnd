# local에서 사용하는 .env (.gitignore)
# 인텔리제이에서 EnvFile 플러그인 설치 후 Edit Configuration -> Enable EnvFile, + 눌러서 .env 추가
# 배포할 경우 Github Secret에 ENV로 추가 필요

# [데이터베이스]
LOCAL_DB_USERNAME=
LOCAL_DB_PASSWORD=
LOCAL_DB_URL=jdbc:mysql://localhost:3306/teumteumeat

DEV_DB_USERNAME=
DEV_DB_PASSWORD=
DEV_DB_URL=jdbc:mysql://host.docker.internal:3306/teumteumeat

PROD_DB_USERNAME=
PROD_DB_PASSWORD=
PROD_DB_URL=jdbc:mysql://host.docker.internal:3306/teumteumeat

LOCAL_REDIS_HOST=localhost
LOCAL_REDIS_PORT=6379

DEV_REDIS_HOST=redis
DEV_REDIS_PORT=6379

PROD_REDIS_HOST=redis
PROD_REDIS_PORT=6379

# [인증/보안]
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRATION_TIME=3600000
JWT_REFRESH_TOKEN_EXPIRATION_TIME=604800000
JWT_REFRESH_TOKEN_REISSUE_LIMIT_DAYS=4

APP_ENCRYPTION_KEY=

# [소셜 로그인]
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_ADMIN_KEY=
KAKAO_SECRET=

GOOGLE_CLIENT_ID=1234-1wrdf342.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_KEY_PATH=file:configs/AuthKey.p8

# [인프라]
LOCAL_SWAGGER_SERVER_URL=http://localhost:8080
DEV_SWAGGER_SERVER_URL=https://api.teumteumeat.co.kr
PROD_SWAGGER_SERVER_URL=https://api.teumteumeat.co.kr

AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=
AWS_S3_BUCKET=
AWS_LAMBDA_AUTH_TOKEN=

OPENAI_API_KEY=

BASE_URL=http://localhost:8080
MAIN_PAGE=/api/v1/users/auth/success
LOGIN_FAIL_PAGE=/api/v1/test/failure
LOCAL_URL=http://localhost:3000
LOCAL_SECURE_URL=https://localhost:3000

DOCKER_COMPOSE_DIR=/home/ubuntu